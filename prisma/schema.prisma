// Schema do banco — Gestão de Processos
// tipo:        "atividade" | "projeto"
// status:      "a_fazer" | "em_andamento" | "concluido"
// prioridade:  "baixa" | "media" | "alta"
// recorrencia: "none" | "diaria" | "semanal" | "mensal"
// papel (chat): "user" | "ia"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tag {
  id       String      @id @default(cuid())
  nome     String      @unique
  cor      String      @default("#6366f1")
  tarefas  TarefaTag[]
}

model TarefaTag {
  tarefaId String
  tagId    String
  tarefa   Tarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([tarefaId, tagId])
}

model Tarefa {
  id             String          @id @default(cuid())
  tipo           String          @default("atividade")
  titulo         String
  descricao      String?
  prazo          DateTime?
  prioridade     String          @default("media")
  status         String          @default("a_fazer")
  recorrencia    String          @default("none")
  recorrenciaAte DateTime?
  nivel          String          @default("operacional")
  dataInicio     DateTime?
  duracaoMin     Int?
  concluidaEm    DateTime?
  criadaEm       DateTime        @default(now())
  atualizadaEm   DateTime        @updatedAt
  tags           TarefaTag[]
  lembretes      Lembrete[]
  // Tarefas: relação auto-referencial (pai = projeto/atividade, filhos = tarefas)
  tarefaPaiId    String?
  tarefaPai      Tarefa?         @relation("Tarefas", fields: [tarefaPaiId], references: [id], onDelete: Cascade)
  tarefas        Tarefa[]        @relation("Tarefas")
  // Dependências
  dependeDe      TarefaDep[]     @relation("TarefaDepende")
  dependentes    TarefaDep[]     @relation("TarefaDependente")
  reunioes       Reuniao[]
}

model TarefaDep {
  tarefaId    String
  dependeDeId String
  tarefa      Tarefa @relation("TarefaDepende", fields: [tarefaId], references: [id], onDelete: Cascade)
  dependeDe   Tarefa @relation("TarefaDependente", fields: [dependeDeId], references: [id], onDelete: Cascade)
  @@id([tarefaId, dependeDeId])
}

model Lembrete {
  id         String   @id @default(cuid())
  tarefa     Tarefa   @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  tarefaId   String
  dispararEm DateTime
  enviado    Boolean  @default(false)
  criadoEm   DateTime @default(now())
}

model MensagemChat {
  id             String   @id @default(cuid())
  papel          String
  conteudo       String
  acaoExecutada  String?
  timestamp      DateTime @default(now())
}

// Preferências do planejador diário (linha única, id=1). Tempos em minutos
// desde a meia-noite (ex.: 540 = 09:00).
model Configuracao {
  id               Int      @id @default(1)
  expedienteInicioMin Int   @default(540)
  expedienteFimMin    Int   @default(1080)
  almocoInicioMin     Int?  @default(720)
  almocoFimMin        Int?  @default(780)
  duracaoPadraoMin    Int   @default(10)
  bufferMin           Int   @default(0)
  atualizadaEm     DateTime @updatedAt
}

// Inscrição de push do navegador (PushSubscription serializada)
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadaEm  DateTime @default(now())
}

// Registro de notificação de prazo já enviada — evita reenvio (nivel: "vencendo" | "atrasada")
model NotificacaoEnviada {
  tarefaId  String
  nivel     String
  enviadaEm DateTime @default(now())
  @@id([tarefaId, nivel])
}

model Reuniao {
  id         String    @id @default(cuid())
  tarefaId   String
  tarefa     Tarefa    @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
  titulo     String?
  dataHora   DateTime?
  duracaoMin Int?
  topicos    Topico[]
  criadaEm   DateTime  @default(now())
}

model Topico {
  id        String   @id @default(cuid())
  reuniaoId String
  reuniao   Reuniao  @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
  titulo    String
  concluido Boolean  @default(false)
  criadoEm  DateTime @default(now())
}
