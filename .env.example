# Supabase — Transaction Pooler (porta 6543) — usado pela aplicação
DATABASE_URL="postgresql://postgres.[projeto]:[senha]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase — Direct Connection (porta 5432) — usado pelo Prisma para migrations
DIRECT_URL="postgresql://postgres.[projeto]:[senha]@aws-0-[regiao].pooler.supabase.com:5432/postgres"

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy..."

# Web Push (VAPID) — gere com: npx web-push generate-vapid-keys --json
# A chave pública é exposta ao navegador (NEXT_PUBLIC_); a privada é secreta.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="B..."
VAPID_PRIVATE_KEY="..."
VAPID_SUBJECT="mailto:voce@exemplo.com"

# Segredo do endpoint de cron (/api/push/check). O Vercel Cron envia
# automaticamente "Authorization: Bearer <CRON_SECRET>" quando esta env existe.
CRON_SECRET="troque-por-uma-string-aleatoria"
